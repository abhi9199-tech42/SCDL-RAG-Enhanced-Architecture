# SCDL-RAG Enhanced Architecture Configuration
# Copy this file to .env and fill in the values

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development           # development | production | test
LOG_LEVEL=info                 # debug | info | warn | error
PORT=3000                      # API server port
HOST=0.0.0.0                   # API server host (0.0.0.0 for Docker, localhost for local)

# ─── Security ────────────────────────────────────────────────────────────────
SCDL_API_KEY=                  # Required: API key for authentication (fail-closed if missing)

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*                 # Comma-separated allowed origins (e.g., https://example.com)

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000     # Rate limit window in ms (1 min)
RATE_LIMIT_MAX=100             # Max requests per window per IP

# ─── Vector Store ────────────────────────────────────────────────────────────
VECTOR_STORE_DIMENSIONS=384    # Embedding dimensions
VECTOR_STORE_SIMILARITY_THRESHOLD=0.75  # Minimum similarity score for matches

# ─── URCM ───────────────────────────────────────────────────────────────────
URCM_RESONANCE_THRESHOLD=0.6   # Minimum resonance for contradiction detection
URCM_CONTRADICTION_SENSITIVITY=0.8  # Sensitivity for contradiction detection (0-1)
URCM_MAX_OSCILLATIONS=10       # Maximum oscillations before convergence

# ─── Retrieval ───────────────────────────────────────────────────────────────
RETRIEVAL_MAX_RESULTS=20       # Maximum results per query
RETRIEVAL_MIN_SCORE=0.5        # Minimum relevance score

# ─── Performance ─────────────────────────────────────────────────────────────
PERFORMANCE_MAX_RESPONSE_TIME=1000  # Max response time in ms
PERFORMANCE_MAX_MEMORY_MB=1024      # Max memory usage in MB
PERFORMANCE_MONITORING_INTERVAL=5000  # Monitoring interval in ms

# ─── Circuit Breaker ─────────────────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5    # Failures before opening circuit
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30000  # Recovery timeout in ms

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_SEMANTIC_MAX_SIZE=1000   # Max semantic cache entries
CACHE_SEMANTIC_TTL=300000      # Semantic cache TTL in ms (5 min)
CACHE_RETRIEVAL_MAX_SIZE=500   # Max retrieval cache entries
